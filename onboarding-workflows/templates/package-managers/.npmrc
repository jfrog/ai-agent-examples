# JFrog Artifactory npm configuration
# Resolve all packages from the Artifactory virtual npm repository
registry=https://{{JFROG_HOSTNAME}}/artifactory/api/npm/{{PROJECT_KEY}}-npm/

# Authentication (developers set JFROG_NPM_TOKEN in their environment)
//{{JFROG_HOSTNAME}}/artifactory/api/npm/{{PROJECT_KEY}}-npm/:_authToken=${JFROG_NPM_TOKEN}
always-auth=true
